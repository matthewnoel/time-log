{
  "name": "time-log",
  "version": "1.0.0",
  "type": "module",
  "description": "A bare-bones local time tracking web page",
  "scripts": {
    "build": "rollup -c",
    "clean": "git restore docs/build/*",
    "dev": "rollup -c -w",
    "host": "sirv docs --host",
    "start": "sirv docs --no-clear",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "licenses": "npx generate-license-file --input package.json --output third-party-licenses.txt --overwrite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewnoel/time-log.git"
  },
  "keywords": [
    "productivity"
  ],
  "author": "Matthew Noel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/matthewnoel/time-log/issues"
  },
  "homepage": "https://github.com/matthewnoel/time-log#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@zerodevx/svelte-toast": "^0.9.6",
    "generate-license-file": "^4.0.0",
    "jsdom": "^29.0.2",
    "rollup": "^4.47.1",
    "rollup-plugin-css-only": "^4.5.2",
    "rollup-plugin-livereload": "^2.0.0",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-svelte": "^7.2.2",
    "sirv-cli": "^3.0.1",
    "svelte": "^5.38.2",
    "svelte-preprocess": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
